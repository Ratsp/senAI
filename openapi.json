  "components": {
    "schemas": {
      "ContactStatusPayload": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "VIP",
              "Blocked",
              "Active",
              "Churned"
            ],
            "title": "Status",
            "description": "The contact's CRM status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "ContactStatusPayload"
      },
      "DraftUpdatePayload": {
        "properties": {
          "proposed_content": {
            "type": "string",
            "minLength": 1,
            "title": "Proposed Content",
            "description": "The updated text content of the draft reply"
          }
        },
        "type": "object",
        "required": [
          "proposed_content"
        ],
        "title": "DraftUpdatePayload"
      },
      "EmailIngestPayload": {
        "properties": {
          "message_id": {
            "type": "string",
            "minLength": 1,
            "title": "Message Id"
          },
          "thread_id": {
            "type": "string",
            "minLength": 1,
            "title": "Thread Id"
          },
          "sender": {
            "type": "string",
            "format": "email",
            "title": "Sender"
          },
          "subject": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Subject"
          },
          "body": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Body"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "recipient": {
            "anyOf": [
              {
                "type": "string",
                "format": "email"
              },
              {
                "type": "null"
              }
            ],
            "title": "Recipient"
          },
          "labels": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Labels"
          }
        },
        "type": "object",
        "required": [
          "message_id",
          "thread_id",
          "sender",
          "timestamp"
        ],
        "title": "EmailIngestPayload"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "IngestAcceptedResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message_id": {
            "type": "string",
            "title": "Message Id"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "message_id"
        ],
        "title": "IngestAcceptedResponse"
      },
      "JobStatusResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Message Id"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          },
          "result": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status"
        ],
        "title": "JobStatusResponse"
      },
      "RespondPayload": {
        "properties": {
          "reply_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Reply Text",
            "description": "The content of the reply or escalation details"
          },
          "escalate": {
            "type": "boolean",
            "title": "Escalate",
            "description": "Whether to escalate this email to human queue"
          }
        },
        "type": "object",
        "required": [
          "escalate"
        ],
        "title": "RespondPayload"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
